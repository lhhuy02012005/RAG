# Database (port 5433 — tách biệt khỏi SlideAgentPro)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/rag

# ChromaDB (port 8002 — tách biệt khỏi SlideAgentPro)
CHROMA_HOST=localhost
CHROMA_PORT=8002

# ===========================================
# Local-only LLM: Ollama (không dùng dịch vụ Gemini/cloud)
# ===========================================

# --- Ollama ---
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
# Multimodal (Recommend)
OLLAMA_MODEL=qwen2.5:3b
# Enable thinking mode for Ollama (default: false — reduces latency for thinking models like qwen3.5)
OLLAMA_ENABLE_THINKING=false

# ===========================================
# KG Embedding (có thể khác LLM provider)
# ===========================================

# --- KG Embedding: Sentence-Transformers (inactive — fully local, no API needed) ---
KG_EMBEDDING_PROVIDER=sentence_transformers
KG_EMBEDDING_MODEL=BAAI/bge-m3
KG_EMBEDDING_DIMENSION=1024

# NexusRAG Pipeline (all optional, defaults shown)
RAG_ENABLED=true
RAG_ENABLE_KG=true
# Global default KG language (can be overridden per workspace in UI)
RAG_KG_LANGUAGE=English
RAG_KG_ENTITY_TYPES=["Organization","Person","Location","Technical_Term","Regulation"]
RAG_ENABLE_IMAGE_EXTRACTION=true
RAG_ENABLE_IMAGE_CAPTIONING=true
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_CHUNK_MAX_TOKENS=512
# Số lượng chunk thô bốc ra từ Vector DB
RAG_VECTOR_PREFETCH=20
RAG_RERANKER_TOP_K=5
RAG_MIN_RELEVANCE_SCORE=0.3

# Processing timeout — stale documents auto-recover to FAILED after this many minutes
# RAG_PROCESSING_TIMEOUT_MINUTES=10

# Pre-ingestion Deduplication (noise filter + content-hash + near-duplicate)
RAG_DEDUP_ENABLED=true
RAG_DEDUP_MIN_CHUNK_LENGTH=50
RAG_DEDUP_NEAR_THRESHOLD=0.85

# Số luồng xử lý Embedding song song (Mac 16GB nên để 1-2, Win 32GB + RTX có thể để 4-8)
NEXUSRAG_KG_EMBEDDING_BATCH_NUM=1

# Giới hạn trích xuất thực thể (Máy yếu để 5, máy mạnh để 15-20)
NEXUSRAG_KG_ENTITY_EXTRACTION_LIMIT=5
MAX_GLEANING=1

# Tự động chọn thiết bị: mps (Mac), cuda (Win+Nvidia), hoặc cpu
NEXUSRAG_EMBEDDING_DEVICE=auto

# Tăng thời gian chờ cho LLM (Ollama) khi máy đang bị Swap RAM
LLM_TIMEOUT=900
EMBEDDING_TIMEOUT=600

# Giới hạn ngữ cảnh đầu vào cho LLM (Tránh tràn RAM/Swap trên Mac)
NEXUSRAG_KG_LLM_MAX_TOKEN_SIZE=1024
# CORS
CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]